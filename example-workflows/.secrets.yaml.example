# Shared secrets for all tentacular example workflows.
# These secrets live at the repo root: <repo-root>/.secrets/
# Run: tntc secrets init --shared (from the repo root)
# Then edit the files in <repo-root>/.secrets/ with actual values.
#
# Each key corresponds to a file in <repo-root>/.secrets/ containing JSON.

github: ""        # {"token": "ghp_..."}
postgres: ""      # {"password": "..."}
slack: ""         # {"webhook_url": "https://hooks.slack.com/services/..."}
azure: ""         # {"sas_token": "..."}
openai: ""        # {"api_key": "sk-..."}
